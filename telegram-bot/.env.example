# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional — get a free key at https://enter.pollinations.ai
# Without a key, the API still works but is rate-limited
POLLINATIONS_API_KEY=

# AI model to use by default (non-paid options):
# deepseek, mistral, qwen-coder, glm, minimax, gemini-fast,
# nova-fast, kimi, openai, openai-fast, claude-fast, perplexity-fast
DEFAULT_MODEL=deepseek

# Default image model: flux, zimage, klein
DEFAULT_IMAGE_MODEL=flux

# How many conversation turns to keep per user (default 20)
MAX_HISTORY_TURNS=20

# Max tool-call iterations per agent response (default 8)
MAX_AGENT_ITERATIONS=8

# Production webhook settings (leave empty for polling / local dev)
# WEBHOOK_URL should be: https://your-domain.com/<your-bot-token>
WEBHOOK_URL=
PORT=8443

# Optional: restrict bot to specific Telegram user IDs
# Comma-separated list of numeric user IDs, e.g.: 123456789,987654321
# Leave empty to allow everyone
ALLOWED_USER_IDS=
